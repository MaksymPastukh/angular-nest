/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./src",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@/*": ["app/*"],
      "@shared/*": ["app/shared/*"],
      "@features/*": ["app/features/*"],
      "@core/*": ["app/core/*"],
      "@marketplace/frontend-auth-data-access": [
        "../../../libs/frontend/auth/data-access/src/index.ts"
      ],
      "@marketplace/frontend-auth-ui": ["../../../libs/frontend/auth/ui/src/index.ts"],
      "@marketplace/frontend-auth-feature-login": [
        "../../../libs/frontend/auth/feature-login/src/index.ts"
      ],
      "@marketplace/frontend-auth-feature-register": [
        "../../../libs/frontend/auth/feature-register/src/index.ts"
      ],
      "@marketplace/frontend-shared-ui": ["../../../libs/frontend/shared/ui/src/index.ts"],
      "@marketplace/frontend-shared-util": [
        "../../../libs/frontend/shared/util/src/index.ts"
      ],
      "@marketplace/frontend-shared-types": [
        "../../../libs/frontend/shared/types/src/index.ts"
      ],
      "@marketplace/frontend-core-auth": ["../../../libs/frontend/core/auth/src/index.ts"],
      "@marketplace/frontend-core-config": ["../../../libs/frontend/core/config/src/index.ts"],
      "@marketplace/frontend-core-http": ["../../../libs/frontend/core/http/src/index.ts"],
      "@marketplace/frontend-core-layout": ["../../../libs/frontend/core/layout/src/index.ts"],
      "@marketplace/frontend-catalog-data-access": [
        "../../../libs/frontend/catalog/data-access/src/index.ts"
      ],
      "@marketplace/frontend-catalog-feature-catalog-page": [
        "../../../libs/frontend/catalog/feature-catalog-page/src/index.ts"
      ],
      "@marketplace/frontend-catalog-feature-filters": [
        "../../../libs/frontend/catalog/feature-filters/src/index.ts"
      ],
      "@marketplace/frontend-catalog-ui": ["../../../libs/frontend/catalog/ui/src/index.ts"],
      "@marketplace/frontend-catalog-util": ["../../../libs/frontend/catalog/util/src/index.ts"],
      "@marketplace/frontend-product-data-access": [
        "../../../libs/frontend/product/data-access/src/index.ts"
      ],
      "@marketplace/frontend-product-feature-product-detail": [
        "../../../libs/frontend/product/feature-product-detail/src/index.ts"
      ],
      "@marketplace/frontend-product-feature-product-questions": [
        "../../../libs/frontend/product/feature-product-questions/src/index.ts"
      ],
      "@marketplace/frontend-product-ui": ["../../../libs/frontend/product/ui/src/index.ts"],
      "@marketplace/frontend-product-util": ["../../../libs/frontend/product/util/src/index.ts"],
      "@marketplace/frontend-wishlist-data-access": [
        "../../../libs/frontend/wishlist/data-access/src/index.ts"
      ],
      "@marketplace/frontend-wishlist-ui": ["../../../libs/frontend/wishlist/ui/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
