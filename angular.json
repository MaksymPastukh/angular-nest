{
  "$schema": "node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "17cfbeef-3f5f-49cb-a6ce-ab2fcd948844"
  },
  "newProjectRoot": "projects",
  "projects": {
    "frontend": {
      "projectType": "application",
      "tags": ["scope:frontend", "type:app"],
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/marketplace-web",
      "sourceRoot": "apps/marketplace-web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "apps/marketplace-web/src/main.ts",
            "polyfills": ["@angular/localize/init"],
            "tsConfig": "apps/marketplace-web/tsconfig.app.json",
            "stylePreprocessorOptions": {
              "includePaths": ["apps/marketplace-web/src/assets/styles"]
            },
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/marketplace-web/public"
              },
              {
                "glob": "**/*",
                "input": "apps/marketplace-web/src/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "apps/marketplace-web/src/assets/styles/styles.scss",
              "apps/marketplace-web/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "frontend:build:production"
            },
            "development": {
              "buildTarget": "frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@nx/eslint:lint",
          "options": {
            "lintFilePatterns": [
              "apps/marketplace-web/src/**/*.ts",
              "apps/marketplace-web/src/**/*.html"
            ]
          }
        }
      }
    }
  }
}
